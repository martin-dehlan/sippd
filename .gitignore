# Environment
.env
.env.*
!.env.example

# Firebase config
# `lib/firebase_options.dart` is FlutterFire-generated and only contains
# the public client identifiers (anon key, project id, sender id, app id).
# Per FlutterFire's own recommendation it is safe to commit so CI can
# satisfy `import 'firebase_options.dart'` in main.dart without a
# generation step. Platform-native configs stay ignored — they're only
# needed at iOS/Android build time and remain per-developer.
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
ios/firebase_app_id_file.json
macos/Runner/GoogleService-Info.plist
macos/firebase_app_id_file.json
firebase.json
.firebaserc

