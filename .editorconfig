# EditorConfig — keeps formatting consistent across IDEs (VS Code,
# Android Studio, IntelliJ, neovim, etc.). `dart format` is the
# authoritative style for Dart files; this file just makes sure
# editors don't fight it on save.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.dart]
indent_size = 2
max_line_length = 80

[*.{yaml,yml,json,toml}]
indent_size = 2

[*.{kt,kts,gradle,groovy}]
indent_size = 4

[*.{swift,h,m,mm}]
indent_size = 4

[*.md]
trim_trailing_whitespace = false  # markdown uses trailing-space line breaks

[Makefile]
indent_style = tab
